@page "/"

<PageTitle>Home</PageTitle>

<MudContainer class="mt-16">
    <MudGrid>
        <MudItem xs="12">
            <MudText Typo="Typo.h1" Align="Align.Center">Välkommen till ????</MudText>  
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="d-flex flex-column align-center justify-center mud-width-full py-8 px-4">
                <MudText Typo="Typo.h5">Om sidan</MudText>
                <MudText Typo="Typo.body1">Detta är X, där du kan öva på kinesiska tecken på ett strukturerat och tydligt sätt. Gå igenom och träna på de officiella tecken som ingår i varje HSK-nivå för att förbereda dig inför HSK-proven.</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="d-flex flex-column align-center justify-center mud-width-full py-8 px-4">
                <MudButton Href="/Practice" Variant="Variant.Filled" Size="Size.Large" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AutoStories">Träna Flashcards</MudButton>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="d-flex flex-column align-center justify-center mud-width-full py-8 px-4">
                <MudText Typo="Typo.h5"> Info om HSK testen</MudText>
                <MudText Typo="Typo.body1">Här är en länk till den officiella sidan <i>Chinese Tests Service Website</i> där det är möjligt att läsa mer om HSK-testerna och deras upplägg </MudText>
                <MudLink Href="https://www.chinesetest.cn/HSK" StartIcon="@Icons.Material.Filled.ArrowOutward">Chinese Tests Service Website</MudLink>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudPaper Class="d-flex align-center justify-center mud-width-full py-8 px-4">
                <MudImage Fluid="true" Src="Images\ChineseTestsServiceWebsite.png" Alt="Bild på Chinese Tests Service Website" Class="rounded-lg" />
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>